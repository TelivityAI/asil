# Required — primary LLM
ANTHROPIC_API_KEY=sk-ant-…

# Required — adversarial gate (must be a different provider than the primary)
OPENAI_API_KEY=sk-…

# Required — absolute path to the target repo ASIL will operate on
REPO_ROOT=/absolute/path/to/your/repo

# Optional — override default state locations
# ASIL_USAGE_DATA_DIR=.asil/usage-data
# ASIL_QUEUE_PATH=.asil/usage-data/queue.json
# ASIL_SKILLS_PATH=.asil/skills
# ASIL_DOMAIN_ANSWERS_PATH=.asil/domain-answers.json
